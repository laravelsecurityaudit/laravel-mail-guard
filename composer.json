{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravelsecurityaudit/laravel-mail-guard",
    "description": "Scan outgoing Laravel mail for leaked secrets, PII, and compliance issues. Preview, block unsafe sends, and fail CI before email leaks.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Andrei Artiushenko",
            "homepage": "https://laravelsecurityaudit.com"
        }
    ],
    "homepage": "https://github.com/laravelsecurityaudit/laravel-mail-guard",
    "support": {
        "issues": "https://github.com/laravelsecurityaudit/laravel-mail-guard/issues",
        "source": "https://github.com/laravelsecurityaudit/laravel-mail-guard"
    },
    "keywords": [
        "laravel",
        "mail",
        "email",
        "security",
        "secrets",
        "pii",
        "compliance",
        "testing"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^12.0 || ^13.0",
        "illuminate/database": "^12.0 || ^13.0",
        "illuminate/events": "^12.0 || ^13.0",
        "illuminate/http": "^12.0 || ^13.0",
        "illuminate/mail": "^12.0 || ^13.0",
        "illuminate/routing": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0",
        "illuminate/view": "^12.0 || ^13.0",
        "symfony/mime": "^7.0 || ^8.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.0 || ^11.0",
        "phpunit/phpunit": "^10.5 || ^11.5 || ^12.5"
    },
    "autoload": {
        "psr-4": {
            "LaravelSecurityAudit\\MailGuard\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelSecurityAudit\\MailGuard\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelSecurityAudit\\MailGuard\\MailGuardServiceProvider"
            ]
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "format": "pint",
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
